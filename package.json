{
  "name": "heic-preview",
  "displayName": "HEIC Image Preview",
  "description": "Preview HEIC images directly in VSCode",
  "version": "2.3.1",
  "publisher": "nuriyev",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "heic",
    "heif",
    "image",
    "preview",
    "viewer"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MahammadNuriyev62/heic-preview"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "heicPreview.heicViewer",
        "displayName": "HEIC Image Viewer",
        "selector": [
          {
            "filenamePattern": "*.heic"
          },
          {
            "filenamePattern": "*.heif"
          },
          {
            "filenamePattern": "*.HEIC"
          },
          {
            "filenamePattern": "*.HEIF"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "heicPreview.openPreview",
        "title": "Open HEIC Preview"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish-minor": "vsce publish minor"
  },
  "author": "Mahammad Nuriyev",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "jest": "^30.3.0",
    "jsdom": "^24.1.3",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "heic-convert": "^2.1.0"
  }
}
